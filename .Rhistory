library(dplyr)
library(kableExtra)
read.csv(file = "../Movie_Data_File.csv", header = TRUE) |>
select(Film_title, Average_rating, Watches,Likes,R_0.5,R_1,R_1.5,R_2,R_2.5,R_3,R_3.5,R_4,R_4.5,R_5,Total_ratings) |>
filter(!is.na(Average_rating)) |>
mutate(R_0.5 = R_0.5 / Total_ratings, R_1 = R_1 / Total_ratings, R_1.5 = R_1.5 / Total_ratings, R_2 = R_2 / Total_ratings,
R_2.5 = R_2.5 / Total_ratings, R_3 = R_3 / Total_ratings, R_3.5 = R_3.5 / Total_ratings, R_4 = R_4 / Total_ratings,
R_4.5 = R_4.5 / Total_ratings, R_5 = R_5 / Total_ratings, Likes = Likes / Watches, Total_ratings = Total_ratings / Watches) |>
rename(Title = Film_title, Av_rat = Average_rating, Ratings = Total_ratings) |>
top_n(5, wt = Watches) |>
kbl(align="c", digits = 3) |>
kable_styling(latex_options = c("striped", "scale_down", "repeat_header"))
cat("\n")
