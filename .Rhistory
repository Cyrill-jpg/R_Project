geom_point(size = 1, aes(color = genre)) +
scale_x_continuous(breaks = seq(2012, 2024, by = 2)) +
labs(
x = "Year",
y = "Number of films",
color = "Genre"
) +
theme(plot.margin = margin(t = 20))
inner_join(movies, genres, by = "id") |>
filter(date >= 2012)|>
group_by(date, genre)|>
summarise(n = n()) |>
ggplot() +
aes(x = date, y = n, group = genre) +
geom_line(aes(color = genre)) +
geom_point(size = 1, aes(color = genre)) +
scale_x_continuous(breaks = seq(2012, 2024, by = 2)) +
labs(
x = "Year",
y = "Number of films",
color = "Genre"
) +
theme(plot.margin = margin(t = 20, b = 20))
