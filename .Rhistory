library(dplyr)
library(ggplot2)
setwd(getwd())
getwd()
movies <- read.csv("/home/cyrill/Downloads/R_Project/movies.csv", fill = TRUE, header = TRUE) |>
select(-description, -tagline) |>
filter(!is.na(date)) |>
filter(!is.na(rating))
studios <- read.csv("studios.csv", fill = TRUE, header = TRUE)
releases <- read.csv("releases.csv", fill = TRUE, header = TRUE)
languages <- read.csv("languages.csv", fill = TRUE, header = TRUE)
genres <- read.csv("genres.csv", fill = TRUE, header = TRUE)
crew <- read.csv("crew.csv", fill = TRUE, header = TRUE)
actors <- read.csv("actors.csv", fill = TRUE, header = TRUE)
countries <- read.csv("countries.csv", fill = TRUE, header = TRUE)
ggplot(genres) + aes(x = genre) + geom_bar()
head(genres, 20)
merge <- inner_join(genres, movies, by = "id")
head(merge)
merge <- inner_join(movies, genres, by = "id")
head(merge)
thing <- merge |>
group_by(id, genres) |>
summarise(n())
thing <- merge |>
group_by(year, genre) |>
summarise(n())
summary(movies)
head(merge)
thing <- merge |>
group_by(date, genre) |>
summarise(n())
head(thing)
head(thing, 10)
View(thing)
p1 <- ggplot(thing) + aes(x = date, y = n(), group = genre) + geom_line()
ggplot(thing) + aes(x = date, y = n(), group = genre) + geom_line()
ggplot(thing) + aes(x = date, y = "n()", group = genre) + geom_line()
thing <- merge |>
group_by(date, genre) |>
summarise(n = n())
