ggplot(thing) + aes(x = date, y = n, group = genre) + geom_line()
thing <- merge |>
filter(date > 2000) |>
group_by(date, genre) |>
summarise(n = n())
ggplot(thing) + aes(x = date, y = n, group = genre) + geom_line()
