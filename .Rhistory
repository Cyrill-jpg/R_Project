plots[[counter]] <- ggplot(letterboxd) + aes(Total_ratings, .data[[i]]) +
geom_point(alpha = 0.1) + labs(x = "Total Ratings")
#| label: fig-figure11
#| fig-cap: "Relationship between each rating and percentage of total ratings"
library(patchwork)
plots <- list()
counter <-  0
for (i in c("R_0.5","R_1","R_1.5","R_2","R_2.5","R_3","R_3.5","R_4","R_4.5","R_5"))
{
counter <- counter + 1
plots[[counter]] <- ggplot(letterboxd) + aes(Total_ratings, .data[[i]]) +
geom_point(alpha = 0.1) + labs(x = "Total Ratings")
}
wrap_plots(plots, ncol = 3)
