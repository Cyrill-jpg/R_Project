geom_line(aes(color = genre)) +
geom_point(size = 1, aes(color = genre)) +
labs(
x = "Year",
y = "Number of films",
color = "Genre"
) +
guides(color=guide_legend(ncol=2)) +
scale_x_continuous(breaks = seq(2012, 2024, by = 2))
